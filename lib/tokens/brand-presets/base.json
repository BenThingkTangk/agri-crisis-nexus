{
  "$schema": "../design-tokens.json",
  "presetId": "base",
  "description": "Structural + default token layer for the universal strategic portal design system. Content-free: brand presets supply overrides + a content payload. Structural constants MUST NOT be overridden by brand presets.",
  "structural": {
    "layout": {
      "navHeightDesktop": "81px",
      "navHeightMobile": "64px",
      "maxWidthContent": "1200px",
      "maxWidthWide": "1440px",
      "maxWidthProse": "720px",
      "gridColumnsDesktop": 12,
      "gridColumnsMobile": 1,
      "gutter": "1.5rem"
    },
    "surface": {
      "glassBlur": "20px"
    },
    "radius": {
      "card": "1rem",
      "pill": "9999px",
      "sm": "0.625rem"
    },
    "spacing": {
      "unit": "0.25rem",
      "cardPad": "1.5rem",
      "cardPadLarge": "2rem",
      "sectionY": "6rem",
      "sectionYLarge": "8rem"
    },
    "typographyFloors": {
      "bodyMin": "1rem",
      "captionMin": "0.75rem",
      "numeric": "tabular-nums lining-nums"
    },
    "motion": {
      "durationInteraction": "180ms",
      "durationEntry": "300ms",
      "durationChart": "700ms",
      "staggerStep": "50ms",
      "easingStandard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "easingEmphasis": "cubic-bezier(0.16, 1, 0.3, 1)",
      "reducedMotion": "disable transforms, parallax, conic rotation, and particle fields; keep opacity and color transitions under 120ms"
    }
  },
  "defaultColorTokens": {
    "dark": {
      "background": "30 20% 6%",
      "backgroundElevated": "30 16% 9%",
      "foreground": "40 30% 92%",
      "foregroundMuted": "38 12% 68%",
      "foregroundFaint": "36 10% 48%",
      "border": "34 14% 20%",
      "borderStrong": "34 14% 28%",
      "surface": "30 15% 10%",
      "surfaceAlt": "30 14% 13%",
      "accentPrimary": "130 48% 46%",
      "accentPrimaryForeground": "30 25% 8%",
      "accentSecondary": "200 70% 52%",
      "accentTertiary": "42 92% 56%",
      "success": "142 50% 42%",
      "warning": "40 92% 52%",
      "danger": "10 74% 50%",
      "info": "200 75% 52%"
    },
    "light": {
      "background": "40 34% 92%",
      "backgroundElevated": "44 40% 96%",
      "foreground": "28 30% 14%",
      "foregroundMuted": "30 15% 34%",
      "foregroundFaint": "32 12% 48%",
      "border": "38 22% 78%",
      "borderStrong": "36 20% 66%",
      "surface": "42 38% 95%",
      "surfaceAlt": "40 30% 90%",
      "accentPrimary": "142 55% 26%",
      "accentPrimaryForeground": "40 40% 97%",
      "accentSecondary": "202 70% 38%",
      "accentTertiary": "38 80% 38%",
      "success": "142 50% 30%",
      "warning": "38 85% 36%",
      "danger": "10 68% 42%",
      "info": "202 70% 38%"
    }
  },
  "defaultTypography": {
    "fontDisplay": "\"Cabinet Grotesk\", \"General Sans\", ui-sans-serif, system-ui, sans-serif",
    "fontBody": "\"Satoshi\", \"General Sans\", ui-sans-serif, system-ui, sans-serif",
    "fontMono": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, monospace"
  },
  "contentPlaceholders": [
    "companyName", "parentCompany", "productName", "flagshipProducts", "marketCategory",
    "targetBuyer", "strategicNarrative", "tractionMetrics", "moatLayers", "proofPoints",
    "callToActionPrimary", "callToActionSecondary", "complianceOrTrustSignals",
    "chartsAndBenchmarks", "founderStory", "valuationOrOutcomeLanguage"
  ]
}
